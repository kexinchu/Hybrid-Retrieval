+static bool
+HnswElementMatchesGuidance(HnswElement element)
+{
+	if (!HnswGuidanceIsActive())
+		return true;
+
+	for (int i = 0; i < element->heaptidsLength; i++)
+	{
+		if (HnswGuidanceAllowsTid(&element->heaptids[i]))
+			return true;
+	}
+
+	return false;
+}
+
+static int
+CompareBlockNumbers(const void *a, const void *b)
+{
+	BlockNumber ba = *((const BlockNumber *) a);
+	BlockNumber bb = *((const BlockNumber *) b);
+
+	if (ba < bb)
+		return -1;
+	if (ba > bb)
+		return 1;
+	return 0;
+}
