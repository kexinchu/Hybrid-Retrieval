+PG_FUNCTION_INFO_V1(vector_hnsw_fragment_epoch_bump_trigger);
+Datum
+vector_hnsw_fragment_epoch_bump_trigger(PG_FUNCTION_ARGS)
+{
+	TriggerData *triggerData;
+	Oid			heapOid;
+	Oid			argTypes[1] = {OIDOID};
+	Datum		values[1];
