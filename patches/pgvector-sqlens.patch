+	SPI_finish();
+	INSTR_TIME_SET_CURRENT(elapsed);
+	INSTR_TIME_SUBTRACT(elapsed, start);
+	cache->bloomBuildMs = INSTR_TIME_GET_MILLISEC(elapsed);
